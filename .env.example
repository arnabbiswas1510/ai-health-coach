# Environment variables for garmin-ai-coach (example only)
# Copy to .env and fill in real values. Do NOT commit real secrets.

# LLM providers (use at least one)
# For direct Google Gemini, use GOOGLE_API_KEY (or GEMINI_API_KEY)
GOOGLE_API_KEY=AIzaSy...
# Other keys if needed:
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=...
DEEPSEEK_API_KEY=...

# Garmin Credentials (optional - can be supplied here or in config/prompt)
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# Athlete Profile overrides (if using environment variables instead of coach_config.yaml)
# ATHLETE_NAME=Arnab                     # Optional override (retrieved automatically from Garmin Connect)
# ATHLETE_AGE=53                         # Used for Max HR / Zone 2 calculation
# TARGET_GOAL=base_building              # e.g., base_building, maintenance
# SYNC_CALENDAR=true                     # Sync workouts to Garmin Connect calendar
# MISSED_RUNS_COUNT=0
# ACCUMULATED_DEBT_KM=0.0

# Context overrides
# CONTEXT_ANALYSIS="My analysis context details..."
# CONTEXT_PLANNING="My planning context details..."

# Extraction overrides
# ACTIVITIES_DAYS=180
# METRICS_DAYS=28
# ENABLE_PLOTTING=false
# HITL_ENABLED=false
# SKIP_SYNTHESIS=false
# OUTPUT_DIR=./data

# Competitions (JSON array)
# COMPETITIONS='[{"name": "Local 10K", "date": "2026-07-04", "race_type": "running", "priority": "A"}]'

# Observability (optional)
LANGSMITH_API_KEY=lsv2_...

# App mode: development | standard | cost_effective | pro
# Provider mapping depends on AI mode:
#   cost_effective -> Google (gemini-1.5-flash) | requires GOOGLE_API_KEY
#   development    -> Google (gemini-1.5-flash) | requires GOOGLE_API_KEY
#   standard       -> Google (gemini-2.0-flash) | requires GOOGLE_API_KEY
#   pro            -> Google (gemini-2.0-pro-exp)| requires GOOGLE_API_KEY
AI_MODE=cost_effective

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
